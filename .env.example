# -------- Required in production --------
NODE_ENV=production
PORT=4000

# MongoDB Atlas (recommended) OR point to a Mongo container.
# Atlas:  mongodb+srv://USER:PASS@cluster.mongodb.net/cadcamsys?retryWrites=true&w=majority
# Local:  mongodb://mongo:27017/cadcamsys
MONGODB_URI=

# Generate a strong value (e.g. openssl rand -hex 64).
# In production the backend refuses to boot if this is empty or "dev_change_me".
JWT_SECRET=
JWT_EXPIRES_IN=7d

# -------- CORS --------
# Public website + forms APIs. Do NOT add admin.cadcamsys.com here — the admin
# portal must be blocked from the public API surface.
PUBLIC_ORIGINS=https://cadcamsys.com,https://www.cadcamsys.com,https://api.cadcamsys.com,https://headless-cms-zeta-three.vercel.app
# Admin API only. The admin portal origin lives here and nowhere else.
ADMIN_ORIGINS=https://admin.cadcamsys.com
ALLOW_ANY_ORIGIN_IN_DEV=false
ENFORCE_ADMIN_ORIGIN_IN_PROD=true

# -------- Cookies --------
# Leave COOKIE_DOMAIN blank if api/admin share a host.
# Set to the apex (".cadcamsys.com") to share session cookies across subdomains.
COOKIE_DOMAIN=
COOKIE_SECURE=true

# -------- Uploads --------
#
# Hostinger Node.js Web App (~/nodejs redeploys on every git push):
#   Leave UPLOAD_DIR=uploads — the app auto-stores files in ~/cadcamsys-uploads
#   (outside nodejs/) when cwd is ~/nodejs or HOSTINGER=1 or NODE_ENV=production.
#   Optional explicit paths:
#     UPLOADS_PERSISTENT_DIR=/home/u449413975/cadcamsys-uploads
#     UPLOADS_BACKUP_DIR=/home/u449413975/cadcamsys-uploads-backup
#   Also set: NODE_ENV=production, PUBLIC_BASE_URL=https://api.cadcamsys.com
#   Create folders in File Browser (sibling to nodejs/, NOT inside nodejs/).
#
# Docker VPS — bind mounts outside the git clone:
#   UPLOADS_BIND_PATH=/home/youruser/cadcamsys-persistent/uploads
#   UPLOADS_BACKUP_BIND_PATH=/home/youruser/cadcamsys-persistent/uploads-backup
#   NEVER run: docker compose down -v
#
UPLOAD_DIR=uploads
HOSTINGER=
UPLOADS_PERSISTENT_DIR=
UPLOADS_BACKUP_DIR=
UPLOADS_BIND_PATH=
UPLOADS_BACKUP_BIND_PATH=
UPLOADS_LEGACY_BIND_PATH=./data/uploads
MAX_UPLOAD_MB=50
PUBLIC_BASE_URL=https://api.cadcamsys.com

# -------- First-run owner bootstrap --------
# Used only when the users collection is empty. Pick a real password.
ADMIN_EMAIL=owner@cadcamsys.com
ADMIN_PASSWORD=

# Set a strong random key if you need to register additional owners after bootstrap.
OWNER_BOOTSTRAP_KEY=

# -------- Email (transactional, for form submissions) --------
# Leave SMTP_HOST blank to disable email — forms still save to the DB.
# Zoho Mail:    smtp.zoho.in / port 587 / SMTP_SECURE=false
# Gmail SMTP example (use an App Password, not your account password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-account@cadcamsys.com
# SMTP_PASSWORD=your-app-password
# SendGrid:     smtp.sendgrid.net / port 587 / SMTP_USER=apikey / SMTP_PASSWORD=YOUR_API_KEY
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Who lead notifications go to (comma-separated). Defaults to ADMIN_EMAIL if blank.
# CONTACT_TO_EMAIL is an alias — use sales@cadcamsys.com for contact form leads.
CONTACT_TO_EMAIL=
EMAIL_ADMIN_TO=
# The From address shown in lead notification + confirmation emails.
EMAIL_FROM="Cadcamsys <no-reply@cadcamsys.com>"

# -------- Visitor tracking --------
# Server-side salt for hashing visitor IPs (we never store raw IPs).
# Generate with: openssl rand -hex 32
# In production the backend refuses to boot if this is blank or "dev_change_me".
TRACKING_SALT=
# How long the anonymous visitor cookie persists, in days.
TRACKING_COOKIE_DAYS=365

# -------- Dev convenience (leave blank in production) --------
# NODE_ENV=development
# PORT=4003
# COOKIE_SECURE=false
# ALLOW_ANY_ORIGIN_IN_DEV=true
# PUBLIC_BASE_URL=http://localhost:4003
# PUBLIC_ORIGINS=http://localhost:3002,http://localhost:5173
# ADMIN_ORIGINS=http://localhost:5173
